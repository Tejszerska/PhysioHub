@{
    ViewData["Title"] = "Check Schedule";
    Layout = "~/Views/Shared/_LayoutAppointments.cshtml";
}

<div class="container my-2">
    <div class="row justify-content-center">
        <div class="col-md-5">
            
            <div class="card border-1 rounded-4">
                <div class="card-body p-5 text-center">
                    
                    <p class="mb-4">
                        Enter your PESEL number to view the list of scheduled treatments for your current stay.
                    </p>                    

                    <form asp-action="Details" method="post" class="text-start">
                        
                        <div class="mb-3 row align-items-center">
                            <label for="pesel" class="col-sm-2 col-form-label small fw-bold">PESEL</label>
    
                            <div class="col-sm-10">
                                <div class="input-group">
                                    <input type="password" id="pesel" name="pesel" class="form-control form-control-lg" required maxlength="11" placeholder="11 digits">
                                </div>
                            </div>
                        </div>

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger d-flex align-items-center small py-2" role="alert">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                <div>@ViewBag.Error</div>
                            </div>
                        }

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm">
                                Check Appointments
                            </button>                           
                        </div>
                    </form>

                </div>
            </div>

            <div class="text-center mt-4">
                <p class="text-muted small">
                    Having trouble accessing your schedule? <br>
                    Contact reception: <strong>555-404-287</strong>
                </p>
            </div>

        </div>
    </div>
</div>