@model IEnumerable<PhysioHub.Data.Data.Scheduling.Stay>

@{
    ViewData["Title"] = "Rehabilitation Stays";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="py-5">
    <div class="container">
        <div class="mb-4">
            <h1 class="physio-text-primary fw-bold">Upcoming Stays</h1>
            <p class="lead text-muted">Check our schedule for upcoming rehabilitation sessions.</p>
        </div>

        <div class="table-responsive shadow-sm">
            <table class="table table-striped table-hover border mb-0">
                <thead class="text-white">
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Name)</th>
                        <th>@Html.DisplayNameFor(model => model.StartDate)</th>
                        <th>@Html.DisplayNameFor(model => model.EndDate)</th>
                        <th class="text-center">Duration</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold align-middle">@item.Name</td>
                            <td class="align-middle">@item.StartDate.ToString("dd.MM.yyyy")</td>
                            <td class="align-middle">@item.EndDate.ToString("dd.MM.yyyy")</td>
                            <td class="text-center align-middle">
                                <span class="badge bg-light text-dark border">
                                    @((item.EndDate - item.StartDate).Days) days
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>