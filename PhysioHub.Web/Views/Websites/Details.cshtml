@model PhysioHub.Data.Data.CMS.Website

@{
    ViewData["Title"] = Model.Title;
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="display-5 fw-bold mb-4 text-center">@Model.Title</h1>
            
            <hr />

            <div class="fs-5 text-dark" >@Html.Raw(Model.Content)</div>
        </div>
    </div>
</div>