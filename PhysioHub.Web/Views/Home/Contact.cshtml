@{
    ViewData["Title"] = "Contact";
}

<section class="py-5">
    <div class="container">
        <div class="mb-2 text-center">
            <h1 class="physio-text-primary fw-bold">Contact Us</h1>
            <p class="fs-4 text-muted">Have questions? We are here to help you get back to health.</p>
        </div>

        <div class="row g-5">
            <div class="col-md-6">
                <div class="p-4 mb-2 physio-bg-alt rounded">
                    <h6 class="fw-bold mb-2 text-uppercase small">Opening Hours</h6>
                    <ul class="list-unstyled mb-0 small">
                        <li class="d-flex justify-content-between"><span>Monday - Friday:</span> <strong>8:00 - 20:00</strong></li>
                        <li class="d-flex justify-content-between"><span>Saturday:</span> <strong>9:00 - 14:00</strong></li>
                        <li class="d-flex justify-content-between text-danger"><span>Sunday:</span> <strong>Closed</strong></li>
                    </ul>
                </div>

                <div class="mb-4">
                    <h4 class="physio-text-primary fw-bold mb-3">Get in Touch</h4>
                    <p>Visit our clinic or reach out to us via phone or email.</p>
                </div>

                <div class="d-flex mb-3">
                    <i class="bi bi-geo-alt-fill physio-text-primary me-2"></i>
                    <h6 class="fw-bold mb-0">East Street 5, New York</h6>
                </div>

                <div class="d-flex mb-3">
                    <i class="bi bi-telephone-fill physio-text-primary me-2"></i>
                    <h6 class="fw-bold mb-0">555-404-287</h6>
                </div>

                <div class="d-flex mb-3">
                    <i class="bi bi-envelope-fill physio-text-primary me-2"></i>
                    <h6 class="fw-bold mb-0">contact@physiohub.com</h6>
                    
                </div>

            </div>

            <div class="col-md-6">
                <h4 class="physio-text-primary fw-bold mb-3">Send a Message</h4>
                <form>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Full Name</label>
                        <input type="text" class="form-control" placeholder="Enter your name">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Email Address</label>
                        <input type="email" class="form-control" placeholder="name@example.com">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Message</label>
                        <textarea class="form-control" rows="5" placeholder="How can we help you?"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary px-5">Send Message</button>
                </form>
            </div>
        </div>

    </div>
</section>