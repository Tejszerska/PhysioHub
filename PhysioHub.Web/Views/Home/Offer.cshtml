@{
    ViewData["Title"] = "Our Services";
}

<section class="py-5">
    <div class="container">
        <div class="mb-5">
            <h1 class="physio-text-primary fw-bold">Comprehensive Care</h1>
            <p class="lead text-muted">Discover our specialized treatments designed for your recovery.</p>
        </div>

        <div class="row align-items-center py-4">
            <div class="col-md-6">
                <h3 class="physio-text-primary fw-bold">Manual Therapy</h3>
                <p>Our manual therapy sessions focus on hands-on techniques to mobilize joints and manipulate soft tissues. This approach is highly effective for reducing chronic pain, improving circulation, and restoring full range of motion after injuries or long periods of inactivity.</p>
                <p class="text-muted small">Perfect for: Back pain, neck stiffness, and joint mobility.</p>
            </div>
            <div class="col-md-6">
                <img src="~/img/article-1.jpg" class="img-fluid rounded shadow-sm" alt="Manual Therapy">
                </div>
            </div>

            <hr class="my-5 opacity-25 w-50 mx-auto">

            <div class="row align-items-center py-4">
                <div class="col-md-6">
                    <img src="~/img/article-2.jpg" class="img-fluid rounded shadow-sm" alt="Sports Rehabilitation">
                    </div>
                <div class="col-md-6">
                    <h3 class="physio-text-primary fw-bold">Sports Rehabilitation</h3>
                    <p>Designed specifically for athletes of all levels. We combine functional exercises with specialized recovery protocols to help you return to your sport safely. We don't just treat the injury; we analyze your movement patterns to prevent future setbacks.</p>
                    <p class="text-muted small">Perfect for: ACL recovery, muscle strains, and performance optimization.</p>
                </div>
                
                </div>

                <hr class="my-5 opacity-25 w-50 mx-auto">

                <div class="row align-items-center py-4">
                    <div class="col-md-6">
                        <h3 class="physio-text-primary fw-bold">Neurological Rehabilitation</h3>
                        <p>We provide expert care for patients recovering from neurological conditions. Our goal is to improve motor functions, balance, and coordination through neuroplasticity-based exercises, helping patients regain their independence and quality of life.</p>
                        <p class="text-muted small">Perfect for: Stroke recovery, Parkinson’s, and balance disorders.</p>
                    </div>
                    <div class="col-md-6">
                        <img src="~/img/article-3.jpg" class="img-fluid rounded shadow-sm" alt="Neurological Rehabilitation">
                        </div>
                    </div>

                </div>
            </section>