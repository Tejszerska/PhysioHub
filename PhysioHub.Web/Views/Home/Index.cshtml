@{
    ViewData["Title"] = "Home";
}

<header class="hero-section text-white mb-2">
    <div class="hero-overlay"></div>
    <div class="container hero-content text-start">
        <h1 class="display-3 fw-bold mb-3">Professional Physiotherapy Services</h1>
        <p class="lead mb-4">We help you regain your strength and mobility. Our expert team uses evidence-based techniques to get you back to your best self.</p>
        
        <div class="d-flex gap-3 justify-content-start">
            <a href="#offer" class="btn btn-primary btn-lg px-4 shadow">Our Offer</a>
            <a href="#contact" class="btn btn-secondary btn-lg px-4 shadow">Contact Us</a>
        </div>
    </div>
</header>

<section class="container mb-2 p-2">

    <div class="row text-center">
        <div class="col-md-4 mb-4">
            <div class="feature-box h-100">
                <div class="feature-icon-circle">
                    <i class="bi bi-person-arms-up"></i>
                </div>
                <h4 class="physio-text-primary">Individual Approach</h4>
                <p class="text-muted">Every patient has a unique story. We create dedicated therapy plans tailored specifically to your goals and condition.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="feature-box h-100">
                <div class="feature-icon-circle">
                    <i class="bi bi-heart-pulse"></i>
                </div>
                <h4 class="physio-text-primary">Modern Equipment</h4>
                <p class="text-muted">We utilize the latest advancements in rehabilitation technology to accelerate your recovery process.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="feature-box h-100">
                <div class="feature-icon-circle">
                    <i class="bi bi-calendar-check"></i>
                </div>
                <h4 class="physio-text-primary">Fast Scheduling</h4>
                <p class="text-muted">Pain doesn't wait. We offer flexible appointment hours and short waiting times for all our treatments.</p>
            </div>
        </div>
    </div>
</section>

<section class="physio-bg-alt p-2">
    <div class="container">
        <div class="text-center mb-3">
            <h2 class="physio-text-primary mb-0">Latest News</h2>            
        </div>
        
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm news-card border-0">
                    <img src=~/img/article-1.jpg class="card-img-top" alt="Shockwave therapy">
                    <div class="card-body">
                        <span class="news-date">April 15, 2026</span>
                        <h5 class="card-title mt-2">Modern Shockwave Therapy</h5>
                        <p class="card-text text-muted small">Starting today, we offer the latest radial shockwave therapy for chronic pain management...</p>
                            <a href="#" class="fw-bold">Read more</a>
                        </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm news-card border-0">
                        <img src=~/img/article-2.jpg class="card-img-top" alt="May stay">
                    <div class="card-body">
                        <span class="news-date">April 10, 2026</span>
                        <h5 class="card-title mt-2">May Stay Enrollment</h5>
                        <p class="card-text text-muted small">Registration for our intensive May rehabilitation stays is now open. Book your spot today!</p>
                            <a href="#" class="fw-bold">Read more</a>
                        </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm news-card border-0">
                            <img src=~/img/article-3.jpg class="card-img-top" alt="Opening hours">
                    <div class="card-body">
                        <span class="news-date">April 05, 2026</span>
                        <h5 class="card-title mt-2">Holiday Opening Hours</h5>
                        <p class="card-text text-muted small">Please check our updated schedule for the upcoming holiday season to plan your visits.</p>
                        <a href="#" class="fw-bold">Read more</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center mb-3">
            <a href="#" class="text-decoration-none fw-bold">View all posts <i class="bi bi-arrow-right"></i></a>
        </div>
    </div>
</section>