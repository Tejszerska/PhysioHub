@{
    ViewData["Title"] = "Your profile";
}
<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="display-6">Witaj, @Model.FirstName!</h2>
            <p class="text-muted">Twoje centrum zdrowia i rehabilitacji.</p>
        </div>
        <div class="col-md-4 text-md-end">
            <span class="badge bg-success p-2">Status: Pacjent Aktywny</span>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">Dane osobowe</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between">
                            <strong>Imię i Nazwisko:</strong>
                            <span>@Model.FirstName @Model.LastName</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <strong>PESEL:</strong>
                            <span>@Model.NationalId</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <strong>Telefon:</strong>
                            <span>@Model.PhoneNumber</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between text-muted small">
                            <span>W systemie od:</span>
                            <span>@Model.CreatedAt.ToShortDateString()</span>
                        </li>
                    </ul>
                    <div class="d-grid mt-3">
                        <a href="#" class="btn btn-outline-primary btn-sm">Edytuj dane</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="card-title mb-0">Moje nadchodzące zabiegi</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Zabieg</th>
                                    <th>Data i godzina</th>
                                    <th>Terapeuta</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><strong>Krioterapia</strong></td>
                                    <td>25.10.2026, 09:30</td>
                                    <td>mgr Jan Kowalski</td>
                                    <td><span class="badge rounded-pill bg-info">Zaplanowano</span></td>
                                </tr>
                                <tr>
                                    <td><strong>Masaż klasyczny</strong></td>
                                    <td>27.10.2026, 11:00</td>
                                    <td>Anna Nowak</td>
                                    <td><span class="badge rounded-pill bg-info">Zaplanowano</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="text-end">
                        <a href="#" class="btn btn-primary">Zarezerwuj nowy zabieg</a>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm text-white bg-dark">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="card-title mb-1">Twój aktywny turnus</h5>
                        <p class="card-text mb-0 small text-secondary">Jesień z Fizjoterapią 2026 (20.10 - 03.11)</p>
                    </div>
                    <a href="#" class="btn btn-light btn-sm">Szczegóły turnusu</a>
                </div>
            </div>
        </div>
    </div>
</div>