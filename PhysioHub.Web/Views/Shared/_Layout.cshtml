<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PhysioHub.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PhysioHub.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark physio-navbar border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/img/logo-web.png" alt="PhysioHub Logo" height="40" class="me-2 d-inline-block align-top" onerror="this.style.display='none'">
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                       @await Html.PartialAsync("NavbarLinks", (IEnumerable<PhysioHub.Data.Data.CMS.Website>)ViewBag.WebsiteModel) 

            </nav>
        </header>
            
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

        @await Html.PartialAsync("ArticlesMinis", (IEnumerable<PhysioHub.Data.Data.CMS.Article>)ViewBag.ArticleMiniModel)

        <footer class="border-top mt-auto pt-3">
            <div class="container">
                <div class="row g-4">
                    <div class="col-md-4">
                        <h5 class="physio-text-primary fw-bold mb-3">PhysioHub</h5>
                        <p class="text-muted small">
                            Professional rehabilitation and physiotherapy services.
                            We help you regain mobility and live without pain.
                        </p>
                        <div class="d-flex gap-3">
                            <a href="#" class="text-muted"><i class="bi bi-facebook fs-5"></i></a>
                            <a href="#" class="text-muted"><i class="bi bi-instagram fs-5"></i></a>
                            <a href="#" class="text-muted"><i class="bi bi-linkedin fs-5"></i></a>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <h6 class="fw-bold mb-3 text-uppercase small">Quick Links</h6>
                        <ul class="list-unstyled small">
                            <li class="mb-2"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Home</a></li>
                            <li class="mb-2"><a asp-controller="Home" asp-action="Offer" class="text-decoration-none text-muted">Our Offer</a></li>
                            <li class="mb-2"><a asp-controller="Home" asp-action="Team" class="text-decoration-none text-muted">Our Team</a></li>
                            <li class="mb-2"><a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-muted">Privacy Policy</a></li>
                        </ul>
                    </div>

                    <div class="col-md-4">
                        <h6 class="fw-bold mb-3 text-uppercase small">Contact</h6>
                        <ul class="list-unstyled small text-muted">
                            <li class="mb-2"><i class="bi bi-geo-alt me-2 text-primary"></i> 123 Health Street, Medical City</li>
                            <li class="mb-2"><i class="bi bi-telephone me-2 text-primary"></i> +48 123 456 789</li>
                            <li class="mb-2"><i class="bi bi-envelope me-2 text-primary"></i> contact@physiohub.com</li>
                        </ul>
                    </div>
                </div>
                </div>
        </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
