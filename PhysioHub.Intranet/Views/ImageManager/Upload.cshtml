@{
    ViewData["Title"] = "Image Manager";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header physio-navbar text-white">
                    <h4 class="mb-0">Upload Image</h4>
                </div>
                <div class="card-body p-4">
                    
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }
                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success">@ViewBag.Success</div>
                    }

                    <form asp-action="Upload" method="post" enctype="multipart/form-data">
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Select Category</label>
                            <select name="category" class="form-select" required>
                                <option value="" disabled selected>Choose category...</option>
                                <option value="Therapist">Therapist</option>
                                <option value="Article">Article</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Entity ID (e.g., 1)</label>
                            <input type="number" name="entityId" class="form-control" required min="1" />
                            <small class="text-muted">Enter the ID of the therapist or article.</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Select Image (.jpg only)</label>
                            <input type="file" name="uploadedFile" class="form-control" accept=".jpg" required />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Upload and Save</button>
                        </div>
                    </form>
                    
                </div>
            </div>
        </div>
    </div>
</div>