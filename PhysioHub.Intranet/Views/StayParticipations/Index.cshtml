@model IEnumerable<PhysioHub.Data.Data.Scheduling.StayParticipation>

@{
    ViewData["Title"] = "Assigned Stay Paticipations";
}
<div class="d-flex align-items-center gap-3 mb-4 justify-content-center flex-wrap">
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Create New
    </a>
    <h1 class="mb-0">Assigned Stay Paticipations</h1>
</div>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th class="text-nowrap">@Html.DisplayNameFor(model => model.Patient)</th>
                <th class="text-nowrap">@Html.DisplayNameFor(model => model.Stay)</th>
                <th class="text-nowrap text-end">Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-nowrap">
                        @Html.DisplayFor(modelItem => item.Patient.FirstName)
                        @Html.DisplayFor(modelItem => item.Patient.LastName)
                    </td>
                    <td class="text-nowrap">@Html.DisplayFor(modelItem => item.Stay.Name)</td>

                    <td class="text-end text-nowrap">
                        <div class="d-flex justify-content-end gap-1">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Details">
                                <i class="bi bi-info-circle"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>