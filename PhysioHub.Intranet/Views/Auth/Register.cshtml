@{
    ViewData["Title"] = "Register Staff";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            
            <div class="card border-1 rounded-4 shadow-sm">
                <div class="card-body p-5">
                    
                    <h3 class="fw-bold mb-3 text-center">Register New Staff</h3>
                    <p class="mb-4 text-muted text-center">
                        Create a new account and assign appropriate permissions.
                    </p>                    

                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success d-flex align-items-center small py-2 mb-4">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            <div>@ViewBag.Success</div>
                        </div>
                    }

                    <form asp-action="Register" method="post">
                        
                        <div class="mb-3">
                            <label for="email" class="form-label small fw-bold">Email Address</label>
                            <input type="email" id="email" name="email" class="form-control" required placeholder="user@physiohub.com">
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label small fw-bold">Password</label>
                            <input type="password" id="password" name="password" class="form-control" required>
                            <small class="text-muted">Must contain an uppercase letter, a number, and a special character.</small>
                        </div>

                        <div class="mb-4">
                            <label for="role" class="form-label small fw-bold">Assign Role</label>
                            <select id="role" name="role" class="form-select" asp-items="@ViewBag.Roles" required>
                                <option value="" disabled selected>-- Select a role --</option>
                            </select>
                        </div>

                        <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm">
                                Create Account
                            </button>                            
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>